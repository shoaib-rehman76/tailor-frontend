{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "skipLibCheck": true, // <--- CRITICAL: Tells TS to skip checking .d.ts files in node_modules
    "outDir": "./build",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "**/__mocks__/*",
    "**/__tests__/*"
  ]
}